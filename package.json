{
  "name": "favorit-pro",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PORT=$(tsx src/lib/find-free-port.ts 3000) next dev -p $PORT",
    "dev:fixed": "next dev -p 3000",
    "build": "next build && mkdir -p .next/standalone/.next && cpy .next/static .next/standalone/.next/ --parents && cpy public/** .next/standalone/public/ --flat",
    "start": "cross-env NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "tsx src/lib/db-check.ts push",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/lib/db-check.ts migrate",
    "db:reset": "tsx src/lib/db-check.ts reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:mongo": "tsx prisma/seed-mongo.ts",
    "db:type": "tsx src/lib/db-check.ts type",
    "port:find": "tsx src/lib/find-free-port.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
