# ============================================================
# FavoritPro — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# The app auto-detects the database type from DATABASE_URL.
# ============================================================

# --- Database (choose ONE) ---
# Option 1: SQLite (default, for local development)
DATABASE_URL="file:./dev.db"

# Option 2: PostgreSQL (for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/favoritpro?schema=public"

# Option 3: MongoDB (alternative, no Prisma)
# DATABASE_URL="mongodb://localhost:27017/favoritpro"

# Force a specific DB type even if URL format is ambiguous:
# DATABASE_TYPE="sqlite" | "postgresql" | "mongodb"

# --- NextAuth (REQUIRED) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Server ---
# Port for the Next.js dev server (auto-detects free port if busy)
PORT=3000

# Socket.IO server URL (for live updates, optional)
SOCKET_SERVER_URL="http://localhost:3003"

# --- App ---
NODE_ENV="development"
DEFAULT_LOCALE="ru"
