# Database
# SQLite для разработки (по умолчанию), PostgreSQL для продакшена
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/favoritpro?schema=public"

# NextAuth (требуется для аутентификации)
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Socket.IO (для live-обновлений, опционально)
SOCKET_SERVER_URL="http://localhost:3003"

# Locale
# next-intl (пока используется только русский)
DEFAULT_LOCALE="ru"
